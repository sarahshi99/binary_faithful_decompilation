          "text": "unsigned char rot13(unsigned char c)\n{\n    if (c >= 'a' && c <= 'z') {\n        return (unsigned char)(c + (c > 'm' ? -13 : 13));\n    }\n    if (c >= 'A' && c <= 'Z') {\n        return (unsigned char)(c + (c > 'M' ? -13 : 13));\n    }\n    return c;\n}",
