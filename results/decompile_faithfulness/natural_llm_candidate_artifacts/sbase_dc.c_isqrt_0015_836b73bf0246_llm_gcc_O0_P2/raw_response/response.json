          "text": "int isqrt(int n)\n{\n    int x;\n    int x1;\n    int s;\n\n    if (n < 1)\n        return 0;\n    if (n == 1)\n        return 1;\n\n    x = n;\n    s = (int)((unsigned int)n + 1U);\n    x1 = s / 2;\n\n    while (x1 < x) {\n        x = x1;\n        s = (int)((unsigned int)x1 + (unsigned int)(n / x1));\n        x1 = s / 2;\n    }\n\n    return x;\n}",
